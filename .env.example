# This file is a template for the environment variables required by the application.
# Copy this file to .env and fill in the values for local development.
# DO NOT COMMIT THE .env FILE.

# Core Services
PORT=8080
OPENROUTER_API_KEY="sk-or-..."

# Upstash Redis — required in production for server-side free-tier audit quotas (3/month per user).
# If UPSTASH_REDIS_REST_URL or UPSTASH_REDIS_REST_TOKEN is missing, the API logs redis_quota_enforcement_disabled at startup and quotas are not enforced.
# Verify both are set in Vercel (or your API host) for the environment that runs api/index.js.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Optional: vector index (separate from quota)
# UPSTASH_VECTOR_REST_URL=""
# UPSTASH_VECTOR_REST_TOKEN=""
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-public-anon-key"

# SAM.gov & Fallback Scraper
SAM_API_KEY="Your SAM.gov API Key"
FIRECRAWL_API_KEY="Your Firecrawl API Key"

# FDIC Enrichment (optional)
FDIC_API_BASE="https://api.fdic.gov/v1"
FDIC_API_KEY=""
FDIC_API_TIMEOUT_MS=15000
FDIC_BANKFIND_CACHE_TTL_MS=86400000

# Persistent Analytics (recommended for real dashboard data)
# Use Railway Postgres or any PostgreSQL-compatible URL.
DATABASE_URL=""
ANALYTICS_DB_SSL=false

# Outbound Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM=""
MAIL_FROM_NAME="BidSmith"
CONTACT_TO=""

# Stripe API Keys & Product IDs
STRIPE_SECRET_KEY="sk_live_..."
VITE_STRIPE_PUBLIC_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ARIS_CALL="price_..."
STRIPE_PRICE_PREMIUM_STANDARD="price_..."
STRIPE_PRICE_PREMIUM_EXPRESS="price_..."
