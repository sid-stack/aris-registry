{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "labs.bidsmith.pro"
        }
      ],
      "destination": "https://www.bidsmith.pro/labs",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.bidsmith.pro/api/$1"
    },
    {
      "source": "/docs",
      "destination": "https://docs.bidsmith.pro"
    },
    {
      "source": "/docs/:match*",
      "destination": "https://docs.bidsmith.pro/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}