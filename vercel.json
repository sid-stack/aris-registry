{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://aris-protocol-staging.up.railway.app/api/$1"
    },
    {
      "source": "/docs",
      "destination": "https://docs.bidsmith.pro"
    },
    {
      "source": "/docs/:match*",
      "destination": "https://docs.bidsmith.pro/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}