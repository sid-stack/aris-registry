{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.bidsmith.pro/api/$1"
    },
    {
      "source": "/docs",
      "destination": "https://arislabs.mintlify.dev/docs"
    },
    {
      "source": "/docs/:match*",
      "destination": "https://arislabs.mintlify.dev/docs/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}